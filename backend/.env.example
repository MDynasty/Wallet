# Environment – copy to .env and fill in
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# Database (SQLite path)
DATABASE_URL="file:../data/wallet.db"

# Exchange rate mock (USD per 1 ETH)
ETH_USD_RATE=3000

# Fee percentage on exchange (0.5 %)
EXCHANGE_FEE_PCT=0.005

# Fee percentage on transfers (0.1 %)
TRANSFER_FEE_PCT=0.001
